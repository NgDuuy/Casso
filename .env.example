# Telegram
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# (Optional) OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# MoMo (Test)
MOMO_ENABLED=true
MOMO_API_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_PARTNER_CODE="YOUR_MOMO_PARTNER_CODE"
MOMO_ACCESS_KEY="YOUR_MOMO_ACCESS_KEY"
MOMO_SECRET_KEY="YOUR_MOMO_SECRET_KEY"

# Public URL where MoMo can call back (use your domain or ngrok)
# Bot exposes:
# - GET  /momo-return
# - POST /momo-ipn
PUBLIC_BASE_URL="https://YOUR_PUBLIC_DOMAIN"
MOMO_RETURN_URL="https://YOUR_PUBLIC_DOMAIN/momo-return"
MOMO_NOTIFY_URL="https://YOUR_PUBLIC_DOMAIN/momo-ipn"

# Optional
MOMO_ORDER_INFO="Thanh toan don tra sua"
MOMO_REQUEST_TYPE="captureWallet"
MOMO_PARTNER_NAME="Casso Milk Tea Bot"
MOMO_STORE_ID="CASSO_STORE"

# Local webhook server to receive return/ipn (must match PUBLIC_BASE_URL)
WEBHOOK_HOST="0.0.0.0"
WEBHOOK_PORT=8000

# Owner (optional: to receive kitchen ticket)
OWNER_NAME="Me"
OWNER_PHONE=""
OWNER_ADDRESS="So 11 duong D9, Khu Do Thi Thien An Nguyen, phuong Dong Hoa, TP HCM"
OWNER_TELEGRAM_CHAT_ID=""

